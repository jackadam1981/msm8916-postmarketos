pkgdesc="Device package for 410stick UFI003-02 LTE dongle (MSM8916)"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="GPL-2.0-only"
arch="aarch64"
options="!check !archcheck"
depends="
	mkbootimg
	postmarketos-base
	soc-qcom-msm8916
	linux-postmarketos-qcom-msm8916
	soc-qcom-msm8916-rproc
"
_pmb_select="soc-qcom-msm8916-rproc"
makedepends="devicepkg-dev"
source="deviceinfo
	msm8916-zhihe-ufi003-mb-v02.dtb"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm644 "$srcdir"/msm8916-zhihe-ufi003-mb-v02.dtb \
		"$pkgdir"/usr/share/dtb/qcom/msm8916-zhihe-ufi003-mb-v02.dtb
}

